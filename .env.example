# ── Meta Cloud API ────────────────────────────────────────────────
# developers.facebook.com → "ewash agent" app → Paramètres → Basique
# Click "Afficher" next to "Clé secrète de l'app"
META_APP_SECRET=***

# A random string YOU pick. Also paste this same value into the
# Meta webhook config screen as "Verify token".
META_VERIFY_TOKEN=***

# Temporary 24h token from "WhatsApp → Configuration de l'API" for first test.
# Replace later with a long-lived System User token (see README).
META_ACCESS_TOKEN=***

# Your Meta test number phone_number_id.
META_PHONE_NUMBER_ID=[REDACTED]
META_WABA_ID=[REDACTED]

# ── Local dev only ────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO

# ── v0.3 admin / persistence ─────────────────────────────────────
# Leave DATABASE_URL empty locally until Postgres is provisioned.
DATABASE_URL=
# Browser-native Basic Auth prompt for /admin.
ADMIN_PASSWORD=***
INTERNAL_CRON_SECRET=***
ADMIN_DEFAULT_LOCALE=fr
