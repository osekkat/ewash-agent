# ── Meta Cloud API ────────────────────────────────────────────────
# developers.facebook.com → "ewash agent" app → Paramètres → Basique
# Click "Afficher" next to "Clé secrète de l'app"
META_APP_SECRET=

# A random string YOU pick. Also paste this same value into the
# Meta webhook config screen as "Verify token".
META_VERIFY_TOKEN=ewash-verify-2026

# Temporary 24h token from "WhatsApp → Configuration de l'API" for first test.
# Replace later with a long-lived System User token (see README).
META_ACCESS_TOKEN=

# Your Meta test number phone_number_id (already saved in memory).
META_PHONE_NUMBER_ID=1079060935296940
META_WABA_ID=812824214769080

# ── Local dev only ────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
